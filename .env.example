# Dataclaw 配置
# 复制为 .env 后修改

# 应用
DCLAW_DEBUG=true
DCLAW_HOST=0.0.0.0
DCLAW_PORT=8000

# 数据库（默认 SQLite，生产可切换 MySQL/PostgreSQL）
DCLAW_DATABASE_URL=sqlite+aiosqlite:///./dataclaw.db

# 数据存储
DCLAW_DATA_DIR=./data
DCLAW_ARTIFACTS_DIR=./data/artifacts

# LLM (Agent 判断层)
DCLAW_LLM_PROVIDER=openai
DCLAW_LLM_MODEL=gpt-4o
DCLAW_LLM_API_KEY=
DCLAW_LLM_MAX_CALLS_PER_SESSION=10
DCLAW_LLM_TIMEOUT_SECONDS=30

# S3 / MinIO（可选）
DCLAW_S3_ENDPOINT=
DCLAW_S3_ACCESS_KEY=
DCLAW_S3_SECRET_KEY=
DCLAW_S3_BUCKET=dataclaw
